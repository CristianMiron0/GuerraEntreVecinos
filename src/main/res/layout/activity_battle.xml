<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#87CEEB">

    <!-- NORTH ZONE: House + Power Bar overlay -->
    <FrameLayout
        android:id="@+id/northSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHeight_percent="0.22">

        <!-- House background -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/house2"
            android:contentDescription="Your House" />

        <!-- Round counter -->
        <TextView
            android:id="@+id/tvRoundCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Round: 1/30"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:padding="6dp"
            android:background="#88000000"
            android:layout_gravity="top|start"
            android:layout_margin="8dp" />

        <!-- Turn indicator -->
        <TextView
            android:id="@+id/tvTurnIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR TURN"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:padding="6dp"
            android:background="#884CAF50"
            android:layout_gravity="top|end"
            android:layout_margin="8dp" />

        <!-- POWER BAR overlays the TOP portion of the house -->
        <!-- layout_gravity="top" pins it to the top; height is fixed -->
        <LinearLayout
            android:id="@+id/powerButtonsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="95dp"
            android:background="#66000000"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGardenHose"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:enabled="false"
                android:text="💧\nHose"
                android:textSize="10sp"
                app:backgroundTint="#2196F3"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNighttimeRelocation"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:enabled="false"
                android:text="🌙\nMove"
                android:textSize="10sp"
                app:backgroundTint="#9C27B0"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTier2Power"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:enabled="false"
                android:text="⚡\nSpecial"
                android:textSize="10sp"
                app:backgroundTint="#FF9800"
                app:cornerRadius="8dp" />

        </LinearLayout>
    </FrameLayout>

    <!-- MIDDLE ZONE: Garden battlefield              -->
    <!-- Contains BOTH grids; only one shows at a time-->
    <FrameLayout
        android:id="@+id/middleSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/northSection"
        app:layout_constraintBottom_toTopOf="@id/southSection"
        app:layout_constraintHeight_percent="0.60">

        <!-- Garden background visible behind everything -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/garden_bg"
            android:contentDescription="Garden" />

        <!-- Enemy Garden (shown during your attack) -->
        <FrameLayout
            android:id="@+id/enemyGardenSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <GridLayout
                android:id="@+id/enemyGrid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:columnCount="8"
                android:rowCount="8" />
        </FrameLayout>

        <!-- Player Garden (shown during enemy attack/defense) -->
        <FrameLayout
            android:id="@+id/playerGardenSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <GridLayout
                android:id="@+id/playerGrid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:columnCount="8"
                android:rowCount="8" />
        </FrameLayout>

    </FrameLayout>

    <!-- SOUTH ZONE: Fence + Angry Neighbour          -->
    <FrameLayout
        android:id="@+id/southSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="0.22">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/south_bg"
            android:contentDescription="South background" />

        <LinearLayout
            android:id="@+id/fenceRow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scaleType="fitXY"
                android:src="@drawable/fence_main"
                android:contentDescription="Fence" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scaleType="fitXY"
                android:src="@drawable/fence_main"
                android:contentDescription="Fence" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scaleType="fitXY"
                android:src="@drawable/fence_main"
                android:contentDescription="Fence" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scaleType="fitXY"
                android:src="@drawable/fence_main"
                android:contentDescription="Fence" />

        </LinearLayout>

        <ImageView
            android:id="@+id/neighborSprite"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:src="@drawable/neighbour_idle"
            android:scaleType="fitCenter"
            android:contentDescription="Angry Neighbour" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>